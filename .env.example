# Copy to .env and fill in. .env is git-ignored — never commit real secrets.

# --- LLM providers (paid APIs are allowed; everything else stays free/local) ---
# Set at least one. Used by the agent graph, the cite-check critic, and the
# LLM-judge eval. Routed/cached through LiteLLM.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Qdrant (local vector DB, via docker compose) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=arxiv_papers

# --- Langfuse (self-hosted observability/tracing, via docker compose) ---
# LANGFUSE_TRACING toggles tracing on/off (off unless truthy AND keys are set).
# The keys below match the docker-compose LANGFUSE_INIT_* dev credentials, so
# tracing works the moment `docker compose up -d` finishes — local dev only.
LANGFUSE_TRACING=false
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-local-dev
LANGFUSE_SECRET_KEY=sk-lf-local-dev

# --- Model overrides (optional; defaults live in code) ---
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# LLM_MODEL=anthropic/claude-sonnet-4-6
