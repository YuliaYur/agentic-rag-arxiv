# Copy to .env and fill in. .env is git-ignored — never commit real secrets.
# `docker compose up` reads this file (the api service loads it), so for the Docker
# path you only need to set OPENAI_API_KEY here; the compose file points the services
# at each other by name.

# --- LLM providers (paid APIs are allowed; everything else stays free/local) ---
# Set at least one. Used by the agent graph, the cite-check critic, and the
# LLM-judge eval. Routed/cached through LiteLLM.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Qdrant (local vector DB, via docker compose) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=arxiv_papers

# --- Langfuse (self-hosted observability/tracing, via docker compose) ---
# LANGFUSE_TRACING toggles tracing on/off (off unless truthy AND keys are set).
# The keys below match the docker-compose LANGFUSE_INIT_* dev credentials, so
# tracing works the moment `docker compose up -d` finishes — local dev only.
LANGFUSE_TRACING=false
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-local-dev
LANGFUSE_SECRET_KEY=sk-lf-local-dev

# --- Model overrides (optional; defaults live in code) ---
# All LLM calls route through LiteLLM, so model strings are LiteLLM-style
# ("gpt-4o-mini", "gpt-4o", "anthropic/claude-sonnet-4-6", ...). LLM_MODEL sets the
# default for every role; the per-role overrides let the agent run a cheap model for
# grade/critic and a stronger one for final synthesis.
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# LLM_MODEL=gpt-4o-mini
# LLM_MODEL_SYNTHESIS=gpt-4o          # stronger model for the final answer
# LLM_MODEL_GRADE=gpt-4o-mini         # cheap model for context-sufficiency grading
# LLM_MODEL_CRITIC=gpt-4o-mini        # cheap model for the citation critic

# --- Semantic cache (LiteLLM over Redis; via docker compose) ---
# Off by default. When on, repeated/semantically-similar LLM calls are served from
# Redis instead of hitting the provider (saves cost + latency; see ADR-0015 for the
# staleness trade-offs).
LLM_CACHE_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
LLM_CACHE_SIMILARITY_THRESHOLD=0.95   # cosine; higher = stricter (fewer false hits)
LLM_CACHE_TTL=3600                    # seconds a cached answer stays valid
# LLM_CACHE_EMBEDDING_MODEL=text-embedding-3-small

# --- API service (FastAPI) + Streamlit UI ---
# API_RATE_LIMIT is a slowapi rule (per client IP) applied to POST /query.
API_RATE_LIMIT=10/minute
# API_URL is where the Streamlit UI looks for the API.
API_URL=http://localhost:8000
